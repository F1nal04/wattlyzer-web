---
import Layout from '../layouts/Layout.astro';
import '../styles/index.css';
---

<Layout>
  <!-- Prevent FOUC: set lang before first paint -->
  <script is:inline>
    (function () {
      var l =
        (typeof localStorage !== 'undefined' &&
          localStorage.getItem('wattlyzer-lang')) ||
        'en';
      document.documentElement.setAttribute('data-lang', l);
    })();
  </script>

  <!-- ── NAV ── -->
  <nav class="nav" id="nav" data-sky-mode="light">
    <div class="nav-left">
      <a href="#top" class="nav-logo">Wattlyzer</a>
      <span class="nav-div"></span>
      <a href="#how" class="nav-link"
        ><span class="en">How it works</span><span class="de">So funktioniert's</span></a
      >
      <a href="#privacy" class="nav-link"
        ><span class="en">Privacy</span><span class="de">Datenschutz</span></a
      >
      <a href="#faq" class="nav-link">FAQ</a>
    </div>
    <div class="nav-right">
      <div class="lang-toggle" id="lang-toggle">
        <button class="lang-btn" data-l="en">EN</button>
        <span class="lang-sep">·</span>
        <button class="lang-btn" data-l="de">DE</button>
      </div>
      <a href="#install" class="nav-cta"
        ><span class="en">Install PWA</span><span class="de">PWA installieren</span></a
      >
    </div>
    <!-- Mobile: lang + hamburger -->
    <div class="nav-mob-right">
      <div class="lang-toggle lang-toggle-mob" id="lang-toggle-mob">
        <button class="lang-btn" data-l="en">EN</button>
        <span class="lang-sep">·</span>
        <button class="lang-btn" data-l="de">DE</button>
      </div>
      <button class="mob-ham" id="mob-ham" aria-label="Menu">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="13" x2="20" y2="13"></line>
          <line x1="4" y1="19" x2="20" y2="19"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero" id="hero" data-sky-mode="light">
    <div id="top"></div>

    <!-- Sky layer -->
    <div class="hero-sky" aria-hidden="true">
      <div id="hero-sun" class="hero-sun"></div>
      <div id="hero-moon" class="hero-moon"></div>
      <div class="hero-cloud cloud-1" id="hc1"></div>
      <div class="hero-cloud cloud-2" id="hc2"></div>
      <div class="hero-hills" id="hero-hills"></div>
    </div>

    <!-- Two-column content -->
    <div class="hero-content">
      <!-- Left: text -->
      <div class="hero-text">
        <!-- Hour strip -->
        <div class="hour-strip" id="hour-strip">
          <div class="hour-dots">
            {[0, 1, 2, 3, 4, 5, 6].map((i) => <span class="hour-dot" data-idx={i}></span>)}
          </div>
          <span class="hour-strip-time" id="hour-strip-time">07:00</span>
        </div>

        <div class="hero-eyebrow">
          <span class="en">FOR GERMAN SOLAR HOMES</span><span class="de">FÜR DEUTSCHE SOLARHAUSHALTE</span>
        </div>

        <h1 class="hero-h1">
          <span class="en">Run it</span><span class="de">Lass es laufen,</span>
          <br />
          <em class="hero-h1b">
            <span class="en">when the sky says so.</span><span class="de">wenn der Himmel es sagt.</span>
          </em>
        </h1>

        <p class="hero-sub">
          <span class="en"
            >Wattlyzer reads the sun, the spot price, and your roof — then tells you the one best
            window today to start the dishwasher, the heat pump, the wall box.</span
          ><span class="de"
            >Wattlyzer liest die Sonne, den Spotpreis und dein Dach — und nennt dir das eine beste
            Fenster heute, um Spülmaschine, Wärmepumpe oder Wallbox zu starten.</span
          >
        </p>

        <div class="hero-cta-row" id="install">
          <a href="#" class="hero-cta-btn" id="hero-cta-btn">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 4v12m0 0l-4-4m4 4l4-4"></path>
              <path d="M5 20h14"></path>
            </svg>
            <span class="en">Install the PWA</span><span class="de">PWA installieren</span>
          </a>
          <span class="hero-cta-sub">
            <span class="en">Free · no account</span><span class="de"
              >Kostenlos · ohne Konto</span
            >
          </span>
        </div>
      </div>

    </div>

    <!-- Scroll cue -->
    <div class="hero-scroll" aria-hidden="true">
      SCROLL
      <span class="hero-scroll-line"></span>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="how" id="how">
    <div class="how-inner">
      <div class="how-header">
        <div>
          <div class="eyebrow">
            <span class="en">HOW IT WORKS</span><span class="de">SO FUNKTIONIERT'S</span>
          </div>
          <h2 class="section-h2">
            <span class="en">Three signals,</span><span class="de">Drei Signale,</span>
            <span class="section-h2-italic"
              ><span class="en"> one window.</span><span class="de"> ein Fenster.</span></span
            >
          </h2>
        </div>
        <p class="section-sub">
          <span class="en">No dashboards. No graphs to read. Just the hour you should press start.</span
          ><span class="de"
            >Kein Dashboard. Keine Diagramme. Nur die Stunde, in der du Start drückst.</span
          >
        </p>
      </div>

      <div class="step-cards">
        <!-- Step 01 -->
        <div class="step-card">
          <div class="step-illus">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              <path
                d="M 10 56 Q 120 -10 230 56"
                fill="none"
                stroke="#1a1410"
                stroke-width="1"
                opacity="0.25"
                stroke-dasharray="2 4"></path>
              {
                [10, 60, 110, 160, 210].map((x) => (
                  <line
                    x1={x}
                    y1="56"
                    x2={x}
                    y2="60"
                    stroke="#1a1410"
                    opacity="0.4"
                    stroke-width="1"
                  />
                ))
              }
              <circle cx="120" cy="14" r="14" fill="url(#sunG)"></circle>
              <defs>
                <radialGradient id="sunG">
                  <stop offset="0%" stop-color="#fff7d6"></stop>
                  <stop offset="60%" stop-color="#ffd86b"></stop>
                  <stop offset="100%" stop-color="#ff9a3c"></stop>
                </radialGradient>
              </defs>
            </svg>
          </div>
          <div class="step-num">01</div>
          <h3 class="step-h"
            ><span class="en">We read the sky.</span><span class="de">Wir lesen den Himmel.</span></h3
          >
          <p class="step-p">
            <span class="en"
              >Hour-by-hour solar forecast for your roof — pitch, azimuth, kWp and shading included.</span
            ><span class="de"
              >Stündliche Solarprognose für dein Dach — Neigung, Ausrichtung, kWp und Verschattung
              inklusive.</span
            >
          </p>
        </div>

        <!-- Step 02 -->
        <div class="step-card">
          <div class="step-illus">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              <path
                d="M 0 30 C 30 38, 50 50, 80 48 S 130 22, 160 24 S 210 50, 240 42"
                fill="none"
                stroke="#1a1410"
                stroke-width="1.6"></path>
              <path
                d="M 0 30 C 30 38, 50 50, 80 48 S 130 22, 160 24 S 210 50, 240 42 L 240 64 L 0 64 Z"
                fill="#1a1410"
                opacity="0.06"></path>
              <circle cx="160" cy="24" r="3.5" fill="#0f7a3a"></circle>
            </svg>
          </div>
          <div class="step-num">02</div>
          <h3 class="step-h"
            ><span class="en">We read the price.</span><span class="de">Wir lesen den Preis.</span></h3
          >
          <p class="step-p">
            <span class="en"
              >Dynamic spot tariffs (Tibber, aWATTar, Octopus) pulled fresh four times an hour.</span
            ><span class="de"
              >Dynamische Spot-Tarife (Tibber, aWATTar, Octopus) — viermal pro Stunde frisch
              geholt.</span
            >
          </p>
        </div>

        <!-- Step 03 -->
        <div class="step-card">
          <div class="step-illus">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              {
                Array.from({ length: 24 }, (_, i) => (
                  <rect
                    x={4 + i * 9.7}
                    y={36}
                    width={6}
                    height={14}
                    fill="#1a1410"
                    opacity={i >= 11 && i <= 14 ? 0.85 : 0.12}
                    rx={1}
                  />
                ))
              }
              <path
                d="M 110 28 L 110 22 L 158 22 L 158 28"
                fill="none"
                stroke="#1a1410"
                stroke-width="1.4"></path>
              <text
                x="134"
                y="14"
                text-anchor="middle"
                font-family="JetBrains Mono, monospace"
                font-size="9"
                fill="#1a1410"
                letter-spacing="2">11–14</text
              >
            </svg>
          </div>
          <div class="step-num">03</div>
          <h3 class="step-h"
            ><span class="en">We pick the hour.</span><span class="de">Wir wählen die Stunde.</span></h3
          >
          <p class="step-p">
            <span class="en"
              >One window. Sunniest, cheapest, or balanced — your call. Slide for duration, done.</span
            ><span class="de"
              >Ein Fenster. Sonnigster, günstigster oder ausgewogener Modus — du entscheidest.
              Laufzeit-Slider, fertig.</span
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRIVACY ── -->
  <section class="privacy" id="privacy">
    <div class="privacy-inner">
      <div class="privacy-header">
        <div>
          <div class="eyebrow eyebrow-light">
            <span class="en">PRIVACY</span><span class="de">DATENSCHUTZ</span>
          </div>
          <h2 class="section-h2 section-h2-light">
            <span class="en">Runs on your phone.</span><span class="de">Läuft auf deinem Gerät.</span>
            <br />
            <span class="section-h2-italic opacity-85"
              ><span class="en">Stays on your phone.</span><span class="de"
                >Bleibt auf deinem Gerät.</span
              ></span
            >
          </h2>
        </div>
        <p class="section-sub section-sub-light">
          <span class="en"
            >Wattlyzer is a Progressive Web App. Forecasts and prices are fetched directly from
            public APIs. Your roof setup never leaves the device. No account, no tracker, no
            analytics SDK.</span
          ><span class="de"
            >Wattlyzer ist eine Progressive Web App. Wetter und Preise kommen direkt aus öffentlichen
            APIs. Deine Dachkonfiguration verlässt das Gerät nicht. Kein Konto, kein Tracker, kein
            Analytics-SDK.</span
          >
        </p>
      </div>

      <div class="privacy-bullets">
        <div class="privacy-bullet">
          <div class="bullet-num">· 01</div>
          <h4 class="bullet-h"><span class="en">No account</span><span class="de">Kein Konto</span></h4>
          <p class="bullet-p">
            <span class="en">Configure your roof, you're done. There is nothing to log into.</span
            ><span class="de"
              >Dach konfigurieren, fertig. Es gibt nichts, wo du dich einloggen müsstest.</span
            >
          </p>
        </div>
        <div class="privacy-bullet">
          <div class="bullet-num">· 02</div>
          <h4 class="bullet-h"
            ><span class="en">No tracking</span><span class="de">Kein Tracking</span></h4
          >
          <p class="bullet-p">
            <span class="en">No analytics, no pixels, no cookies. Open the network tab and check.</span
            ><span class="de"
              >Keine Analytics, keine Pixel, keine Cookies. Network-Tab öffnen und nachsehen.</span
            >
          </p>
        </div>
        <div class="privacy-bullet">
          <div class="bullet-num">· 03</div>
          <h4 class="bullet-h">Local first</h4>
          <p class="bullet-p">
            <span class="en">Tariffs and forecasts cached on-device.</span
            ><span class="de"
              >Tarife und Prognosen lokal gecached.</span
            >
          </p>
        </div>
        <div class="privacy-bullet">
          <div class="bullet-num">· 04</div>
          <h4 class="bullet-h">Open source</h4>
          <p class="bullet-p">
            <span class="en">Source on <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="inline-link">GitHub</a>, MIT licensed. Read it, fork it, host it yourself.</span
            ><span class="de"
              >Quellcode auf <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="inline-link">GitHub</a>, MIT-Lizenz. Lesen, forken, selbst hosten — alles erlaubt.</span
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="faq" id="faq">
    <div class="faq-inner">
      <div class="faq-header">
        <div class="eyebrow">FAQ</div>
        <h2 class="section-h2">
          <em class="section-h2-italic"
            ><span class="en">Common questions.</span><span class="de">Häufige Fragen.</span></em
          >
        </h2>
      </div>

      <div class="faq-list">
        <!-- item 1 -->
        <div class="faq-item" data-open="false">
          <button class="faq-q">
            <span class="faq-q-text">
              <span class="en">Which tariffs are supported?</span>
              <span class="de">Welche Tarife werden unterstützt?</span>
            </span>
            <span class="faq-icon">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              <span class="en"
                >Any dynamic electricity tariff that exposes hourly spot prices. Fixed-rate contracts cannot be optimized — there is nothing to compare.</span
              ><span class="de"
                >Jeder dynamische Stromtarif, der stündliche Spotpreise bereitstellt. Festpreisverträge lassen sich nicht optimieren — es gibt nichts zu vergleichen.</span
              >
            </div>
          </div>
        </div>

        <!-- item 2 -->
        <div class="faq-item" data-open="false">
          <button class="faq-q">
            <span class="faq-q-text">
              <span class="en">Do I need a smart meter?</span>
              <span class="de">Brauche ich ein Smart Meter?</span>
            </span>
            <span class="faq-icon">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              <span class="en"
                >No. Wattlyzer recommends a window — you start the appliance. We never touch your
                meter or your inverter.</span
              ><span class="de"
                >Nein. Wattlyzer empfiehlt nur ein Fenster — du startest das Gerät selbst. Wir
                greifen weder auf Zähler noch auf Wechselrichter zu.</span
              >
            </div>
          </div>
        </div>

        <!-- item 3 -->
        <div class="faq-item" data-open="false">
          <button class="faq-q">
            <span class="faq-q-text">
              <span class="en">How accurate is the solar forecast?</span>
              <span class="de">Wie genau ist die Solarprognose?</span>
            </span>
            <span class="faq-icon">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              <span class="en"
                >We use the forecast.solar API with your roof's location, tilt, azimuth, and installed kWp. Accuracy depends on local weather conditions.</span
              ><span class="de"
                >Wir nutzen die forecast.solar API mit Standort, Neigung, Ausrichtung und installierter kWp deines Dachs. Die Genauigkeit hängt von den lokalen Wetterbedingungen ab.</span
              >
            </div>
          </div>
        </div>

        <!-- item 4 -->
        <div class="faq-item" data-open="false">
          <button class="faq-q">
            <span class="faq-q-text">
              <span class="en">Is it really free?</span>
              <span class="de">Ist es wirklich kostenlos?</span>
            </span>
            <span class="faq-icon">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              <span class="en"
                >Yes. No tier, no upsell. If you want to support the project, star it on <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="inline-link">GitHub</a> or
                send a postcard.</span
              ><span class="de"
                >Ja. Keine Tarife, keine Upsells. Wenn du das Projekt unterstützen willst — Stern auf
                <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="inline-link">GitHub</a> oder eine Postkarte.</span
              >
            </div>
          </div>
        </div>

        <!-- item 5 -->
        <div class="faq-item" data-open="false">
          <button class="faq-q">
            <span class="faq-q-text">
              <span class="en">Why a PWA and not the App Store?</span>
              <span class="de">Warum eine PWA und kein App Store?</span>
            </span>
            <span class="faq-icon">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              <span class="en"
                >Because the App Store would slow shipping, take a cut, and demand an account system
                we do not need. The PWA installs in two taps from Safari or Chrome.</span
              ><span class="de"
                >Weil der App Store das Ausliefern verlangsamt, eine Provision nimmt und einen
                Account-Zwang bedeutet, den wir nicht brauchen. Die PWA installiert sich in zwei Taps
                aus Safari oder Chrome.</span
              >
            </div>
          </div>
        </div>

        <div class="faq-border-bottom"></div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">Wattlyzer</div>
          <p class="footer-tagline">
            <span class="en">Made in Berlin for German rooftops.</span><span class="de"
              >Made in Berlin, für deutsche Dächer.</span
            >
          </p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/F1nal04/wattlyzer-app" class="footer-link" target="_blank" rel="noopener">GitHub</a>
        </div>
        <div class="footer-links">
          <a href="#privacy" class="footer-link"
            ><span class="en">Privacy</span><span class="de">Datenschutz</span></a
          >
          <a href="/impressum" class="footer-link">Impressum</a>
        </div>
      </div>

      <div class="footer-bottom">
        <span class="footer-copy"
          ><span class="en">© 2026 Wattlyzer. MIT licensed.</span><span class="de"
            >© 2026 Wattlyzer. MIT-Lizenz.</span
          ></span
        >
        <div class="footer-lang">
          <button class="footer-lang-btn" data-l="en" id="footer-lang-en">EN</button>
          <span>·</span>
          <button class="footer-lang-btn" data-l="de" id="footer-lang-de">DE</button>
        </div>
      </div>
    </div>
  </footer>

  <!-- ── MOBILE MENU SHEET ── -->
  <div id="mob-sheet" class="mob-sheet" aria-hidden="true">
    <div class="mob-sheet-overlay" id="mob-overlay"></div>
    <div class="mob-sheet-content" id="mob-sheet-content">
      <div class="mob-sheet-close-row">
        <button class="mob-sheet-close" id="mob-sheet-close" aria-label="Close">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          >
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
      <a href="#how" class="mob-nav-link" id="mob-link-how"
        ><span class="en">How it works</span><span class="de">So funktioniert's</span></a
      >
      <a href="#privacy" class="mob-nav-link" id="mob-link-privacy"
        ><span class="en">Privacy</span><span class="de">Datenschutz</span></a
      >
      <a href="#faq" class="mob-nav-link" id="mob-link-faq">FAQ</a>
      <a href="/impressum" class="mob-nav-link" id="mob-link-imp">Impressum</a>
      <a href="#install" class="mob-cta" id="mob-cta"
        ><span class="en">Install PWA</span><span class="de">PWA installieren</span></a
      >
    </div>
  </div>
</Layout>

<script>
  // ── Sky theme ──
  const SKY_HOURS = [7, 10, 13, 16, 18, 20, 22];

  interface SkyTheme {
    sky: [string, string, string];
    mode: 'light' | 'dark';
    sunCore: string;
    sunMid: string;
    sunOuter: string;
  }

  function skyTheme(h: number): SkyTheme {
    if (h < 5)
      return {
        sky: ['#0f1430', '#1d2148', '#3a2c52'],
        mode: 'dark',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 8)
      return {
        sky: ['#fcd9a7', '#f8b88a', '#e88c80'],
        mode: 'light',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 16)
      return {
        sky: ['#bde4ff', '#fef0c7', '#fcd28a'],
        mode: 'light',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 19)
      return {
        sky: ['#f9c180', '#e87a5e', '#7a3e6a'],
        mode: 'dark',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    return {
      sky: ['#2b2649', '#5b3a6a', '#8d4a6e'],
      mode: 'dark',
      sunCore: '#fff7d6',
      sunMid: '#ffd86b',
      sunOuter: '#ff9a3c',
    };
  }

  // ── State ──
  let hourIdx = 0;
  let currentSkyMode: 'dark' | 'light' = 'light';

  // ── DOM refs ──
  const hero = document.getElementById('hero')!;
  const nav = document.getElementById('nav')!;
  const heroSun = document.getElementById('hero-sun') as HTMLElement;
  const heroMoon = document.getElementById('hero-moon') as HTMLElement;
  const hourStripTime = document.getElementById('hour-strip-time')!;
  const hourDots = document.querySelectorAll<HTMLElement>('.hour-dot');

  function updateSky(hour: number) {
    const t = skyTheme(hour);
    const [c1, c2, c3] = t.sky;
    const isDark = t.mode === 'dark';
    currentSkyMode = t.mode;

    // Hero gradient
    hero.style.setProperty('--sky-c1', c1);
    hero.style.setProperty('--sky-c2', c2);
    hero.style.setProperty('--sky-c3', c3);
    hero.setAttribute('data-sky-mode', t.mode);

    // Nav
    nav.setAttribute('data-sky-mode', t.mode);

    // Sun / moon
    const showSun = hour >= 6 && hour <= 19;
    const sunX = Math.max(0.05, Math.min(0.95, (hour - 6) / 14));
    const sunY = 1 - Math.sin(Math.PI * Math.max(0, Math.min(1, (hour - 6) / 14)));
    if (showSun) {
      heroSun.style.opacity = '0.96';
      heroSun.style.left = `calc(${sunX * 100}% - 90px)`;
      heroSun.style.top = `calc(${10 + sunY * 25}% - 90px)`;
      heroSun.style.background = `radial-gradient(circle, ${t.sunCore} 0%, ${t.sunMid} 45%, ${t.sunOuter} 75%, rgba(255,154,60,0) 100%)`;
      heroSun.style.boxShadow = `0 0 120px 30px ${t.sunMid}66`;
      heroMoon.style.opacity = '0';
    } else {
      heroSun.style.opacity = '0';
      heroMoon.style.opacity = '1';
      heroMoon.style.left = `calc(${sunX * 100}% - 56px)`;
    }

    // Hour strip
    hourStripTime.textContent = String(hour).padStart(2, '0') + ':00';
    hourDots.forEach((dot, i) => {
      if (SKY_HOURS[i] === hour) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });

    // Mobile sheet sky mode
    const mobContent = document.getElementById('mob-sheet-content');
    if (mobContent) mobContent.setAttribute('data-sky-mode', t.mode);
  }

  // Kick off cycling
  function tick() {
    updateSky(SKY_HOURS[hourIdx]);
    hourIdx = (hourIdx + 1) % SKY_HOURS.length;
  }
  tick();
  setInterval(tick, 4400);

  // ── FAQ Accordion ──
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.faq-item')!;
      const isOpen = item.dataset.open === 'true';
      document.querySelectorAll<HTMLElement>('.faq-item').forEach((el) => {
        el.dataset.open = 'false';
        el.querySelector('button')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.dataset.open = 'true';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Mobile menu ──
  const mobSheet = document.getElementById('mob-sheet')!;
  const mobHam = document.getElementById('mob-ham')!;
  const mobOverlay = document.getElementById('mob-overlay')!;
  const mobClose = document.getElementById('mob-sheet-close')!;

  function openMenu() {
    mobSheet.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    mobSheet.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  mobHam.addEventListener('click', openMenu);
  mobClose.addEventListener('click', closeMenu);
  mobOverlay.addEventListener('click', closeMenu);
  document.querySelectorAll('.mob-nav-link, .mob-cta').forEach((el) => {
    el.addEventListener('click', closeMenu);
  });

  // ── Language toggle ──
  function setLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem('wattlyzer-lang', lang);
    }
    // Update active state on all lang buttons
    document.querySelectorAll<HTMLButtonElement>('.lang-btn, .footer-lang-btn').forEach((btn) => {
      const l = btn.dataset.l || btn.dataset.langBtn;
      if (l === lang) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  // Wire up all lang buttons
  document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
    btn.addEventListener('click', () => setLang(btn.dataset.l!));
  });

  // Set initial active state
  const initLang =
    (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
  setLang(initLang);
</script>
