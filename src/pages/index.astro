---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <script is:inline>
    (function () {
      var l = (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
      document.documentElement.setAttribute('data-lang', l);
    })();
  </script>

  <!-- ── NAV ── -->
  <nav
    class="absolute top-0 left-0 right-0 z-20 px-8 py-[22px] flex items-center justify-between gap-4 transition-colors duration-[1200ms] nav"
    id="nav"
    data-sky-mode="light"
  >
    <div class="flex items-center gap-6 flex-nowrap whitespace-nowrap">
      <a href="#top" class="nav-logo font-display text-[22px] font-normal tracking-[-0.01em] no-underline transition-colors duration-[1200ms]">Wattlyzer</a>
      <span class="inline-block w-px h-[18px] bg-current opacity-20 shrink-0"></span>
      <a href="#how" class="font-sans text-[13px] font-medium no-underline py-2 px-1 opacity-[0.82] hover:opacity-100 transition-opacity duration-200 max-[900px]:hidden">
        <span class="en">How it works</span><span class="de">So funktioniert's</span>
      </a>
      <a href="#privacy" class="font-sans text-[13px] font-medium no-underline py-2 px-1 opacity-[0.82] hover:opacity-100 transition-opacity duration-200 max-[900px]:hidden">
        <span class="en">Privacy</span><span class="de">Datenschutz</span>
      </a>
      <a href="#faq" class="font-sans text-[13px] font-medium no-underline py-2 px-1 opacity-[0.82] hover:opacity-100 transition-opacity duration-200 max-[900px]:hidden">FAQ</a>
    </div>
    <div class="flex items-center gap-4 flex-nowrap whitespace-nowrap max-[900px]:hidden" id="nav-right">
      <div class="lang-toggle inline-flex items-center gap-0.5 px-1 py-0.5 rounded-full border transition-[background,border-color] duration-[1200ms]" id="lang-toggle">
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-current opacity-50 font-medium transition-opacity duration-200 hover:opacity-100" data-l="en">EN</button>
        <span class="opacity-30 text-[10px]">·</span>
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-current opacity-50 font-medium transition-opacity duration-200 hover:opacity-100" data-l="de">DE</button>
      </div>
      <a href="#install" class="nav-cta px-4 py-[10px] rounded-full font-sans text-[13px] font-semibold no-underline tracking-[0.01em] shadow-[0_4px_14px_rgba(0,0,0,0.18)] transition-[background,color] duration-[1200ms] whitespace-nowrap">
        <span class="en">Install PWA</span><span class="de">PWA installieren</span>
      </a>
    </div>
    <div class="hidden max-[900px]:flex items-center gap-[10px]" id="nav-mob-right">
      <div class="lang-toggle inline-flex items-center gap-0.5 px-1 py-0.5 rounded-full border transition-[background,border-color] duration-[1200ms]" id="lang-toggle-mob">
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-current opacity-50 font-medium" data-l="en">EN</button>
        <span class="opacity-30 text-[10px]">·</span>
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-current opacity-50 font-medium" data-l="de">DE</button>
      </div>
      <button class="mob-ham w-9 h-9 rounded-full p-0 border cursor-pointer inline-flex items-center justify-center transition-[background,border-color] duration-[1200ms] text-current" id="mob-ham" aria-label="Menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="13" x2="20" y2="13"></line>
          <line x1="4" y1="19" x2="20" y2="19"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section
    class="hero-bg relative w-full min-h-screen overflow-hidden flex items-center"
    id="hero"
    data-sky-mode="light"
  >
    <div id="top"></div>

    <div class="absolute inset-0 pointer-events-none z-[1]" aria-hidden="true">
      <div id="hero-sun" class="hero-sun"></div>
      <div id="hero-moon" class="hero-moon"></div>
      <div class="hero-cloud cloud-1" id="hc1"></div>
      <div class="hero-cloud cloud-2" id="hc2"></div>
      <div class="hero-hills" id="hero-hills"></div>
    </div>

    <div class="relative z-[5] w-full max-w-[800px] mx-auto px-20 pt-[120px] pb-[100px] max-[900px]:px-[22px] max-[900px]:pt-20 max-[900px]:pb-[60px]">
      <div class="sky-text">
        <div class="inline-flex items-center gap-2 px-3 py-[6px] rounded-full bg-white/10 backdrop-blur-md border border-white/[0.18] font-mono text-[11px] tracking-[0.14em] mb-[18px]" id="hour-strip">
          <div class="inline-flex gap-1">
            {[0, 1, 2, 3, 4, 5, 6].map((i) => (
              <span class="hour-dot w-[5px] h-[5px] rounded-full bg-current opacity-25 transition-opacity duration-[600ms] inline-block" data-idx={i}></span>
            ))}
          </div>
          <span id="hour-strip-time">07:00</span>
        </div>

        <div class="font-mono text-[11px] tracking-[0.22em] font-medium opacity-65 mb-4">
          <span class="en">FOR GERMAN SOLAR HOMES</span><span class="de">FÜR DEUTSCHE SOLARHAUSHALTE</span>
        </div>

        <h1 class="m-0 font-display font-normal text-[clamp(56px,6.1vw,88px)] leading-[0.96] tracking-[-0.035em] text-balance text-current max-[900px]:text-[clamp(44px,13vw,64px)]">
          <span class="en">Run it</span><span class="de">Lass es laufen,</span>
          <br />
          <em class="not-italic font-light opacity-[0.92]">
            <span class="en">when the sky says so.</span><span class="de">wenn der Himmel es sagt.</span>
          </em>
        </h1>

        <p class="mt-[26px] max-w-[480px] text-[17px] leading-[1.55] opacity-[0.82] text-pretty max-[900px]:text-[15.5px]">
          <span class="en">Wattlyzer reads the sun, the spot price, and your roof — then tells you the one best window today to start the dishwasher, the heat pump, the wall box.</span
          ><span class="de">Wattlyzer liest die Sonne, den Spotpreis und dein Dach — und nennt dir das eine beste Fenster heute, um Spülmaschine, Wärmepumpe oder Wallbox zu starten.</span>
        </p>

        <div class="mt-9 flex items-center gap-[18px] flex-wrap max-[480px]:flex-col max-[480px]:items-start max-[480px]:gap-3" id="install">
          <a href="#" class="hero-cta-btn inline-flex items-center gap-[10px] px-[26px] py-4 rounded-full font-sans text-[15px] font-semibold no-underline tracking-[0.01em] shadow-[0_12px_32px_rgba(20,16,30,0.28)] whitespace-nowrap" id="hero-cta-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4v12m0 0l-4-4m4 4l4-4"></path>
              <path d="M5 20h14"></path>
            </svg>
            <span class="en">Install the PWA</span><span class="de">PWA installieren</span>
          </a>
          <span class="font-mono text-[11px] tracking-[0.1em] opacity-60">
            <span class="en">Free · no account</span><span class="de">Kostenlos · ohne Konto</span>
          </span>
        </div>
      </div>
    </div>

    <div class="hero-scroll absolute bottom-7 left-1/2 -translate-x-1/2 font-mono text-[10px] tracking-[0.22em] opacity-55 flex flex-col items-center gap-2 z-[5]" aria-hidden="true">
      SCROLL
      <span class="w-px h-8 bg-current opacity-70"></span>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="bg-warm text-ink py-[140px] px-20 font-sans max-[900px]:py-[72px] max-[900px]:px-[22px]" id="how">
    <div class="max-w-[1240px] mx-auto">
      <div class="grid grid-cols-2 gap-20 items-end mb-20 max-[900px]:grid-cols-1 max-[900px]:gap-5 max-[900px]:mb-8">
        <div>
          <div class="font-mono text-[11px] tracking-[0.22em] text-ink/55 font-medium">
            <span class="en">HOW IT WORKS</span><span class="de">SO FUNKTIONIERT'S</span>
          </div>
          <h2 class="mt-4 mb-0 font-display font-normal text-[clamp(42px,4.4vw,64px)] leading-none tracking-[-0.03em] text-balance">
            <span class="en">Three signals,</span><span class="de">Drei Signale,</span>
            <em class="not-italic font-light"><span class="en"> one window.</span><span class="de"> ein Fenster.</span></em>
          </h2>
        </div>
        <p class="text-[17px] leading-[1.55] text-ink/[0.72] m-0 max-w-[460px] text-pretty">
          <span class="en">No dashboards. No graphs to read. Just the hour you should press start.</span
          ><span class="de">Kein Dashboard. Keine Diagramme. Nur die Stunde, in der du Start drückst.</span>
        </p>
      </div>

      <div class="grid grid-cols-3 gap-8 max-[900px]:grid-cols-1 max-[900px]:gap-4">
        <div class="flex flex-col gap-4 min-h-[240px] p-8 pb-9 bg-white rounded-[22px] border border-ink/[0.06] shadow-[0_1px_0_rgba(255,255,255,0.6)_inset,0_24px_48px_-28px_rgba(20,16,30,0.18)]">
          <div class="w-full h-16">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              <path d="M 10 56 Q 120 -10 230 56" fill="none" stroke="#1a1410" stroke-width="1" opacity="0.25" stroke-dasharray="2 4"></path>
              {[10, 60, 110, 160, 210].map((x) => (
                <line x1={x} y1="56" x2={x} y2="60" stroke="#1a1410" opacity="0.4" stroke-width="1" />
              ))}
              <circle cx="120" cy="14" r="14" fill="url(#sunG)"></circle>
              <defs>
                <radialGradient id="sunG">
                  <stop offset="0%" stop-color="#fff7d6"></stop>
                  <stop offset="60%" stop-color="#ffd86b"></stop>
                  <stop offset="100%" stop-color="#ff9a3c"></stop>
                </radialGradient>
              </defs>
            </svg>
          </div>
          <div class="font-mono text-[11px] tracking-[0.18em] text-ink/45 font-semibold">01</div>
          <h3 class="m-0 font-display font-normal text-[28px] leading-[1.1] tracking-[-0.02em]">
            <span class="en">We read the sky.</span><span class="de">Wir lesen den Himmel.</span>
          </h3>
          <p class="m-0 text-[14.5px] leading-[1.55] text-ink/70 text-pretty">
            <span class="en">Hour-by-hour solar forecast for your roof — pitch, azimuth, kWp and shading included.</span
            ><span class="de">Stündliche Solarprognose für dein Dach — Neigung, Ausrichtung, kWp und Verschattung inklusive.</span>
          </p>
        </div>

        <div class="flex flex-col gap-4 min-h-[240px] p-8 pb-9 bg-white rounded-[22px] border border-ink/[0.06] shadow-[0_1px_0_rgba(255,255,255,0.6)_inset,0_24px_48px_-28px_rgba(20,16,30,0.18)]">
          <div class="w-full h-16">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              <path d="M 0 30 C 30 38, 50 50, 80 48 S 130 22, 160 24 S 210 50, 240 42" fill="none" stroke="#1a1410" stroke-width="1.6"></path>
              <path d="M 0 30 C 30 38, 50 50, 80 48 S 130 22, 160 24 S 210 50, 240 42 L 240 64 L 0 64 Z" fill="#1a1410" opacity="0.06"></path>
              <circle cx="160" cy="24" r="3.5" fill="#0f7a3a"></circle>
            </svg>
          </div>
          <div class="font-mono text-[11px] tracking-[0.18em] text-ink/45 font-semibold">02</div>
          <h3 class="m-0 font-display font-normal text-[28px] leading-[1.1] tracking-[-0.02em]">
            <span class="en">We read the price.</span><span class="de">Wir lesen den Preis.</span>
          </h3>
          <p class="m-0 text-[14.5px] leading-[1.55] text-ink/70 text-pretty">
            <span class="en">Dynamic spot tariffs (Tibber, aWATTar, Octopus) pulled fresh four times an hour.</span
            ><span class="de">Dynamische Spot-Tarife (Tibber, aWATTar, Octopus) — viermal pro Stunde frisch geholt.</span>
          </p>
        </div>

        <div class="flex flex-col gap-4 min-h-[240px] p-8 pb-9 bg-white rounded-[22px] border border-ink/[0.06] shadow-[0_1px_0_rgba(255,255,255,0.6)_inset,0_24px_48px_-28px_rgba(20,16,30,0.18)]">
          <div class="w-full h-16">
            <svg viewBox="0 0 240 64" width="100%" height="64" style="display:block">
              {Array.from({ length: 24 }, (_, i) => (
                <rect x={4 + i * 9.7} y={36} width={6} height={14} fill="#1a1410" opacity={i >= 11 && i <= 14 ? 0.85 : 0.12} rx={1} />
              ))}
              <path d="M 110 28 L 110 22 L 158 22 L 158 28" fill="none" stroke="#1a1410" stroke-width="1.4"></path>
              <text x="134" y="14" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1410" letter-spacing="2">11–14</text>
            </svg>
          </div>
          <div class="font-mono text-[11px] tracking-[0.18em] text-ink/45 font-semibold">03</div>
          <h3 class="m-0 font-display font-normal text-[28px] leading-[1.1] tracking-[-0.02em]">
            <span class="en">We pick the hour.</span><span class="de">Wir wählen die Stunde.</span>
          </h3>
          <p class="m-0 text-[14.5px] leading-[1.55] text-ink/70 text-pretty">
            <span class="en">One window. Sunniest, cheapest, or balanced — your call. Slide for duration, done.</span
            ><span class="de">Ein Fenster. Sonnigster, günstigster oder ausgewogener Modus — du entscheidest. Laufzeit-Slider, fertig.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRIVACY ── -->
  <section class="bg-ink text-cream py-[140px] px-20 font-sans max-[900px]:py-[72px] max-[900px]:px-[22px]" id="privacy">
    <div class="max-w-[1240px] mx-auto">
      <div class="grid grid-cols-2 gap-20 items-start mb-16 max-[900px]:grid-cols-1 max-[900px]:gap-5 max-[900px]:mb-8">
        <div>
          <div class="font-mono text-[11px] tracking-[0.22em] text-cream/55 font-medium">
            <span class="en">PRIVACY</span><span class="de">DATENSCHUTZ</span>
          </div>
          <h2 class="mt-4 mb-0 font-display font-normal text-[clamp(42px,4.4vw,64px)] leading-none tracking-[-0.03em] text-balance text-cream">
            <span class="en">Runs on your phone.</span><span class="de">Läuft auf deinem Gerät.</span>
            <br />
            <em class="not-italic font-light opacity-85"><span class="en">Stays on your phone.</span><span class="de">Bleibt auf deinem Gerät.</span></em>
          </h2>
        </div>
        <p class="text-[17px] leading-[1.55] text-cream/[0.72] m-0 max-w-[480px] text-pretty">
          <span class="en">Wattlyzer is a Progressive Web App. Forecasts and prices are fetched directly from public APIs. Your roof setup never leaves the device. No account, no tracker, no analytics SDK.</span
          ><span class="de">Wattlyzer ist eine Progressive Web App. Wetter und Preise kommen direkt aus öffentlichen APIs. Deine Dachkonfiguration verlässt das Gerät nicht. Kein Konto, kein Tracker, kein Analytics-SDK.</span>
        </p>
      </div>

      <div class="grid grid-cols-4 gap-6 pt-10 border-t border-cream/[0.12] max-[900px]:grid-cols-1">
        <div class="flex flex-col">
          <div class="font-mono text-[10px] tracking-[0.22em] text-cream/45 font-semibold mb-3">· 01</div>
          <h4 class="m-0 mb-2 font-display font-normal text-[22px] leading-[1.15] tracking-[-0.01em] text-cream">
            <span class="en">No account</span><span class="de">Kein Konto</span>
          </h4>
          <p class="m-0 text-[13.5px] leading-[1.55] text-cream/[0.72] text-pretty">
            <span class="en">Configure your roof, you're done. There is nothing to log into.</span
            ><span class="de">Dach konfigurieren, fertig. Es gibt nichts, wo du dich einloggen müsstest.</span>
          </p>
        </div>
        <div class="flex flex-col">
          <div class="font-mono text-[10px] tracking-[0.22em] text-cream/45 font-semibold mb-3">· 02</div>
          <h4 class="m-0 mb-2 font-display font-normal text-[22px] leading-[1.15] tracking-[-0.01em] text-cream">
            <span class="en">No tracking</span><span class="de">Kein Tracking</span>
          </h4>
          <p class="m-0 text-[13.5px] leading-[1.55] text-cream/[0.72] text-pretty">
            <span class="en">No analytics, no pixels, no cookies. Open the network tab and check.</span
            ><span class="de">Keine Analytics, keine Pixel, keine Cookies. Network-Tab öffnen und nachsehen.</span>
          </p>
        </div>
        <div class="flex flex-col">
          <div class="font-mono text-[10px] tracking-[0.22em] text-cream/45 font-semibold mb-3">· 03</div>
          <h4 class="m-0 mb-2 font-display font-normal text-[22px] leading-[1.15] tracking-[-0.01em] text-cream">Local first</h4>
          <p class="m-0 text-[13.5px] leading-[1.55] text-cream/[0.72] text-pretty">
            <span class="en">Tariffs and forecasts cached on-device.</span
            ><span class="de">Tarife und Prognosen lokal gecached.</span>
          </p>
        </div>
        <div class="flex flex-col">
          <div class="font-mono text-[10px] tracking-[0.22em] text-cream/45 font-semibold mb-3">· 04</div>
          <h4 class="m-0 mb-2 font-display font-normal text-[22px] leading-[1.15] tracking-[-0.01em] text-cream">Open source</h4>
          <p class="m-0 text-[13.5px] leading-[1.55] text-cream/[0.72] text-pretty">
            <span class="en">Source on <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="underline underline-offset-[3px] opacity-80 hover:opacity-100 transition-opacity duration-200 text-current">GitHub</a>, MIT licensed. Read it, fork it, host it yourself.</span
            ><span class="de">Quellcode auf <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="underline underline-offset-[3px] opacity-80 hover:opacity-100 transition-opacity duration-200 text-current">GitHub</a>, MIT-Lizenz. Lesen, forken, selbst hosten — alles erlaubt.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="bg-warm text-ink py-[140px] px-20 font-sans max-[900px]:py-[72px] max-[900px]:px-[22px]" id="faq">
    <div class="max-w-[920px] mx-auto">
      <div class="mb-14">
        <div class="font-mono text-[11px] tracking-[0.22em] text-ink/55 font-medium">FAQ</div>
        <h2 class="mt-4 mb-0 font-display font-normal text-[clamp(42px,4.4vw,64px)] leading-none tracking-[-0.03em] text-balance">
          <em class="not-italic font-light"><span class="en">Common questions.</span><span class="de">Häufige Fragen.</span></em>
        </h2>
      </div>

      <div class="flex flex-col">
        {[
          {
            en: 'Which tariffs are supported?',
            de: 'Welche Tarife werden unterstützt?',
            aEn: 'Tibber, aWATTar, Octopus Germany, and any plan that publishes EPEX spot pricing. We do not yet support fixed-rate Stadtwerke contracts — there is nothing to optimize.',
            aDe: 'Tibber, aWATTar, Octopus Deutschland und alle Tarife, die EPEX-Spotpreise veröffentlichen. Feste Stadtwerke-Verträge unterstützen wir noch nicht — da gibt es nichts zu optimieren.',
          },
          {
            en: 'Do I need a smart meter?',
            de: 'Brauche ich ein Smart Meter?',
            aEn: 'No. Wattlyzer recommends a window — you start the appliance. We never touch your meter or your inverter.',
            aDe: 'Nein. Wattlyzer empfiehlt nur ein Fenster — du startest das Gerät selbst. Wir greifen weder auf Zähler noch auf Wechselrichter zu.',
          },
          {
            en: 'How accurate is the solar forecast?',
            de: 'Wie genau ist die Solarprognose?',
            aEn: 'We use Open-Meteo\'s hour-resolution irradiance model combined with your tilt, azimuth and shading profile. Within ~15% on clear days, looser on broken cloud.',
            aDe: 'Wir nutzen das stundenscharfe Strahlungsmodell von Open-Meteo und kombinieren es mit deiner Neigung, Ausrichtung und Verschattung. Bei klarem Himmel ~15% Genauigkeit, bei wechselnden Wolken etwas lockerer.',
          },
          {
            en: 'Is it really free?',
            de: 'Ist es wirklich kostenlos?',
            aEnHtml: true,
            aDe: 'Ja. Keine Tarife, keine Upsells. Wenn du das Projekt unterstützen willst — Stern auf GitHub oder eine Postkarte.',
          },
          {
            en: 'Why a PWA and not the App Store?',
            de: 'Warum eine PWA und kein App Store?',
            aEn: 'Because the App Store would slow shipping, take a cut, and demand an account system we do not need. The PWA installs in two taps from Safari or Chrome.',
            aDe: 'Weil der App Store das Ausliefern verlangsamt, eine Provision nimmt und einen Account-Zwang bedeutet, den wir nicht brauchen. Die PWA installiert sich in zwei Taps aus Safari oder Chrome.',
          },
        ].map((item, idx) => (
          <div class="faq-item border-t border-ink/[0.14]" data-open="false">
            <button class="faq-q w-full py-[26px] border-none bg-transparent cursor-pointer flex justify-between items-center gap-6 text-left">
              <span class="font-display font-normal text-[22px] leading-[1.25] tracking-[-0.01em] text-ink">
                <span class="en">{item.en}</span>
                <span class="de">{item.de}</span>
              </span>
              <span class="faq-icon w-7 h-7 rounded-full shrink-0 bg-ink/[0.06] inline-flex items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M12 5v14M5 12h14"></path>
                </svg>
              </span>
            </button>
            <div class="faq-a">
              <div class="faq-a-inner pb-7 pr-16 max-[900px]:pr-0 text-[15px] leading-[1.6] text-ink/[0.72] text-pretty">
                {item.aEnHtml ? (
                  <span class="en">Yes. No tier, no upsell. If you want to support the project, star it on <a href="https://github.com/F1nal04/wattlyzer-app" target="_blank" rel="noopener" class="underline underline-offset-[3px] opacity-80 hover:opacity-100 transition-opacity duration-200 text-current">GitHub</a> or send a postcard.</span>
                ) : (
                  <span class="en">{item.aEn}</span>
                )}
                <span class="de">{item.aDe}</span>
              </div>
            </div>
          </div>
        ))}
        <div class="border-t border-ink/[0.14] h-0"></div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="bg-dark text-cream py-20 px-20 pb-10 font-sans max-[900px]:py-12 max-[900px]:px-[22px] max-[900px]:pb-8">
    <div class="max-w-[1240px] mx-auto">
      <div class="grid grid-cols-[1.2fr_1fr_1fr] gap-10 mb-14 max-[900px]:grid-cols-2 max-[900px]:gap-6 max-[480px]:grid-cols-1">
        <div class="max-[900px]:col-span-2 max-[480px]:col-span-1">
          <div class="font-display text-[28px] font-normal tracking-[-0.01em]">Wattlyzer</div>
          <p class="mt-2 mb-0 font-display italic font-light text-[16px] text-cream/55">
            <span class="en">Made in Berlin for German rooftops.</span><span class="de">Made in Berlin, für deutsche Dächer.</span>
          </p>
        </div>
        <div class="flex flex-col gap-[10px]">
          <a href="https://github.com/F1nal04/wattlyzer-app" class="text-cream/70 text-[13px] no-underline hover:text-cream transition-colors duration-200" target="_blank" rel="noopener">GitHub</a>
        </div>
        <div class="flex flex-col gap-[10px]">
          <a href="#privacy" class="text-cream/70 text-[13px] no-underline hover:text-cream transition-colors duration-200">
            <span class="en">Privacy</span><span class="de">Datenschutz</span>
          </a>
          <a href="/impressum" class="text-cream/70 text-[13px] no-underline hover:text-cream transition-colors duration-200">Impressum</a>
        </div>
      </div>

      <div class="pt-7 border-t border-cream/[0.12] flex justify-between items-center font-mono text-[11px] tracking-[0.1em] text-cream/45">
        <span>
          <span class="en">© 2026 Wattlyzer. MIT licensed.</span><span class="de">© 2026 Wattlyzer. MIT-Lizenz.</span>
        </span>
        <div class="inline-flex items-center gap-3">
          <button class="footer-lang-btn bg-transparent border-none cursor-pointer text-cream/40 font-mono text-[11px] tracking-[0.1em] font-medium hover:text-cream transition-colors duration-200" data-l="en" id="footer-lang-en">EN</button>
          <span>·</span>
          <button class="footer-lang-btn bg-transparent border-none cursor-pointer text-cream/40 font-mono text-[11px] tracking-[0.1em] font-medium hover:text-cream transition-colors duration-200" data-l="de" id="footer-lang-de">DE</button>
        </div>
      </div>
    </div>
  </footer>

  <!-- ── MOBILE MENU SHEET ── -->
  <div id="mob-sheet" class="mob-sheet" aria-hidden="true">
    <div class="absolute inset-0 bg-black/40" id="mob-overlay"></div>
    <div
      class="mob-sheet-content relative z-[1] mt-16 w-[calc(100%-32px)] max-w-[440px] rounded-[22px] px-[22px] py-3 pb-[22px] shadow-[0_20px_60px_rgba(0,0,0,0.4)] transition-colors duration-[400ms]"
      id="mob-sheet-content"
    >
      <div class="flex justify-end mb-1">
        <button class="w-8 h-8 rounded-full bg-transparent border-none cursor-pointer text-current inline-flex items-center justify-center" id="mob-sheet-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
      <a href="#how" class="mob-nav-link block py-[14px] font-sans text-[18px] font-medium text-current no-underline border-t border-ink/10" id="mob-link-how">
        <span class="en">How it works</span><span class="de">So funktioniert's</span>
      </a>
      <a href="#privacy" class="mob-nav-link block py-[14px] font-sans text-[18px] font-medium text-current no-underline border-t border-ink/10" id="mob-link-privacy">
        <span class="en">Privacy</span><span class="de">Datenschutz</span>
      </a>
      <a href="#faq" class="mob-nav-link block py-[14px] font-sans text-[18px] font-medium text-current no-underline border-t border-ink/10" id="mob-link-faq">FAQ</a>
      <a href="/impressum" class="mob-nav-link block py-[14px] font-sans text-[18px] font-medium text-current no-underline border-t border-ink/10" id="mob-link-imp">Impressum</a>
      <a href="#install" class="mob-cta block mt-4 px-[18px] py-[14px] rounded-full text-center bg-ink text-cream font-sans text-[14px] font-semibold no-underline" id="mob-cta">
        <span class="en">Install PWA</span><span class="de">PWA installieren</span>
      </a>
    </div>
  </div>
</Layout>

<script>
  // ── Sky theme ──
  const SKY_HOURS = [7, 10, 13, 16, 18, 20, 22];

  interface SkyTheme {
    sky: [string, string, string];
    mode: 'light' | 'dark';
    sunCore: string;
    sunMid: string;
    sunOuter: string;
  }

  function skyTheme(h: number): SkyTheme {
    if (h < 5)
      return {
        sky: ['#0f1430', '#1d2148', '#3a2c52'],
        mode: 'dark',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 8)
      return {
        sky: ['#fcd9a7', '#f8b88a', '#e88c80'],
        mode: 'light',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 16)
      return {
        sky: ['#bde4ff', '#fef0c7', '#fcd28a'],
        mode: 'light',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    if (h < 19)
      return {
        sky: ['#f9c180', '#e87a5e', '#7a3e6a'],
        mode: 'dark',
        sunCore: '#fff7d6',
        sunMid: '#ffd86b',
        sunOuter: '#ff9a3c',
      };
    return {
      sky: ['#2b2649', '#5b3a6a', '#8d4a6e'],
      mode: 'dark',
      sunCore: '#fff7d6',
      sunMid: '#ffd86b',
      sunOuter: '#ff9a3c',
    };
  }

  // ── State ──
  let hourIdx = 0;
  let currentSkyMode: 'dark' | 'light' = 'light';

  // ── DOM refs ──
  const hero = document.getElementById('hero')!;
  const nav = document.getElementById('nav')!;
  const heroSun = document.getElementById('hero-sun') as HTMLElement;
  const heroMoon = document.getElementById('hero-moon') as HTMLElement;
  const hourStripTime = document.getElementById('hour-strip-time')!;
  const hourDots = document.querySelectorAll<HTMLElement>('.hour-dot');

  function updateSky(hour: number) {
    const t = skyTheme(hour);
    const [c1, c2, c3] = t.sky;
    const isDark = t.mode === 'dark';
    currentSkyMode = t.mode;

    // Hero gradient
    hero.style.setProperty('--sky-c1', c1);
    hero.style.setProperty('--sky-c2', c2);
    hero.style.setProperty('--sky-c3', c3);
    hero.setAttribute('data-sky-mode', t.mode);

    // Nav
    nav.setAttribute('data-sky-mode', t.mode);

    // Sun / moon
    const showSun = hour >= 6 && hour <= 19;
    const sunX = Math.max(0.05, Math.min(0.95, (hour - 6) / 14));
    const sunY = 1 - Math.sin(Math.PI * Math.max(0, Math.min(1, (hour - 6) / 14)));
    if (showSun) {
      heroSun.style.opacity = '0.96';
      heroSun.style.left = `calc(${sunX * 100}% - 90px)`;
      heroSun.style.top = `calc(${10 + sunY * 25}% - 90px)`;
      heroSun.style.background = `radial-gradient(circle, ${t.sunCore} 0%, ${t.sunMid} 45%, ${t.sunOuter} 75%, rgba(255,154,60,0) 100%)`;
      heroSun.style.boxShadow = `0 0 120px 30px ${t.sunMid}66`;
      heroMoon.style.opacity = '0';
    } else {
      heroSun.style.opacity = '0';
      heroMoon.style.opacity = '1';
      heroMoon.style.left = `calc(${sunX * 100}% - 56px)`;
    }

    // Hour strip
    hourStripTime.textContent = String(hour).padStart(2, '0') + ':00';
    hourDots.forEach((dot, i) => {
      if (SKY_HOURS[i] === hour) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });

    // Mobile sheet sky mode
    const mobContent = document.getElementById('mob-sheet-content');
    if (mobContent) mobContent.setAttribute('data-sky-mode', t.mode);
  }

  // Kick off cycling
  function tick() {
    updateSky(SKY_HOURS[hourIdx]);
    hourIdx = (hourIdx + 1) % SKY_HOURS.length;
  }
  tick();
  setInterval(tick, 4400);

  // ── FAQ Accordion ──
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.faq-item')!;
      const isOpen = item.dataset.open === 'true';
      document.querySelectorAll<HTMLElement>('.faq-item').forEach((el) => {
        el.dataset.open = 'false';
        el.querySelector('button')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.dataset.open = 'true';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Mobile menu ──
  const mobSheet = document.getElementById('mob-sheet')!;
  const mobHam = document.getElementById('mob-ham')!;
  const mobOverlay = document.getElementById('mob-overlay')!;
  const mobClose = document.getElementById('mob-sheet-close')!;

  function openMenu() {
    mobSheet.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    mobSheet.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  mobHam.addEventListener('click', openMenu);
  mobClose.addEventListener('click', closeMenu);
  mobOverlay.addEventListener('click', closeMenu);
  document.querySelectorAll('.mob-nav-link, .mob-cta').forEach((el) => {
    el.addEventListener('click', closeMenu);
  });

  // ── Language toggle ──
  function setLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem('wattlyzer-lang', lang);
    }
    // Update active state on all lang buttons
    document.querySelectorAll<HTMLButtonElement>('.lang-btn, .footer-lang-btn').forEach((btn) => {
      const l = btn.dataset.l || btn.dataset.langBtn;
      if (l === lang) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  // Wire up all lang buttons
  document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
    btn.addEventListener('click', () => setLang(btn.dataset.l!));
  });

  // Set initial active state
  const initLang =
    (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
  setLang(initLang);
</script>
