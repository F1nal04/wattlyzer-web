---
import Layout from '../layouts/Layout.astro';
import '../styles/impressum.css';
---

<Layout
  title="Wattlyzer · Impressum"
  description="Angaben gemäß § 5 TMG — Legal notice for Wattlyzer."
>
  <!-- Prevent FOUC -->
  <script is:inline>
    (function () {
      var l =
        (typeof localStorage !== 'undefined' &&
          localStorage.getItem('wattlyzer-lang')) ||
        'en';
      document.documentElement.setAttribute('data-lang', l);
    })();
  </script>

  <div class="topbar">
    <a class="brand" href="/">Wattlyzer</a>
    <div class="topbar-right">
      <a href="/" class="back-link">← wattlyzer.app</a>
      <div class="lang-toggle" id="lang-toggle">
        <button class="lang-btn" data-l="en">EN</button>
        <span class="lang-sep">·</span>
        <button class="lang-btn" data-l="de">DE</button>
      </div>
    </div>
  </div>

  <main class="wrap">
    <div class="eyebrow">§ 5 TMG</div>
    <h1>
      Legal <em>notice.</em>
    </h1>
    <div class="subtitle">
      <span class="en">Information according to § 5 TMG</span>
      <span class="de">Angaben gemäß § 5 TMG</span>
    </div>

    <!-- Operator -->
    <section class="imp-section">
      <h2><span class="en">Operator</span><span class="de">Betreiber</span></h2>
      <p>Leon Bojanowski<br />Marienstraße 3b<br />14532 Stahnsdorf<br /><span class="en">Germany</span><span class="de">Deutschland</span></p>
    </section>

    <!-- Contact -->
    <section class="imp-section">
      <h2><span class="en">Contact</span><span class="de">Kontakt</span></h2>
      <p>leongaborbojanowski@proton.me</p>
    </section>

    <!-- Disclaimer -->
    <section class="imp-section">
      <h2><span class="en">Informational use only</span><span class="de">Nur zur Information</span></h2>
      <p>
        <span class="en">Wattlyzer provides estimates and recommendation support, not guaranteed outcomes or professional advice. All calculations are presented as estimates and are not suitable for critical decisions without independent verification.</span>
        <span class="de">Wattlyzer liefert Schätzungen und Empfehlungsunterstützung, keine garantierten Ergebnisse oder professionelle Beratung. Alle Berechnungen sind Schätzwerte und nicht für kritische Entscheidungen ohne unabhängige Überprüfung geeignet.</span>
      </p>
    </section>
  </main>

  <div class="foot">
    © 2026 Wattlyzer · Impressum
  </div>
</Layout>


<script>
  function setLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem('wattlyzer-lang', lang);
    }
    document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.l === lang);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
    btn.addEventListener('click', () => setLang(btn.dataset.l!));
  });

  const initLang =
    (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
  setLang(initLang);
</script>
