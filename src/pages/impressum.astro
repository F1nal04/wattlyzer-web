---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Wattlyzer · Impressum"
  description="Angaben gemäß § 5 TMG — Legal notice for Wattlyzer."
>
  <script is:inline>
    (function () {
      var l = (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
      document.documentElement.setAttribute('data-lang', l);
    })();
  </script>

  <div class="flex justify-between items-center px-8 py-5 border-b border-ink/10 max-[600px]:px-5 max-[600px]:py-4">
    <a href="/" class="font-display text-[22px] font-normal tracking-[-0.01em] no-underline text-ink">Wattlyzer</a>
    <div class="flex items-center gap-6">
      <a href="/" class="font-sans text-[13px] text-ink/70 no-underline hover:text-ink transition-colors duration-200">← wattlyzer.app</a>
      <div class="inline-flex items-center gap-0.5 px-1 py-0.5 rounded-full bg-ink/[0.06] border border-ink/10" id="lang-toggle">
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-ink/40 font-medium hover:text-ink transition-colors duration-200" data-l="en">EN</button>
        <span class="text-ink/20 text-[10px]">·</span>
        <button class="lang-btn bg-transparent border-none cursor-pointer px-[6px] py-1 font-mono text-[11px] tracking-[0.1em] text-ink/40 font-medium hover:text-ink transition-colors duration-200" data-l="de">DE</button>
      </div>
    </div>
  </div>

  <main class="max-w-[760px] mx-auto px-8 pt-20 pb-[120px] max-[600px]:px-5 max-[600px]:pt-12 max-[600px]:pb-20">
    <div class="font-mono text-[11px] tracking-[0.22em] text-ink/55 font-medium uppercase">§ 5 TMG</div>
    <h1 class="mt-[14px] mb-[6px] font-display font-normal text-[clamp(42px,6vw,64px)] leading-none tracking-[-0.03em] text-ink">
      Legal <em class="italic font-light opacity-85">notice.</em>
    </h1>
    <div class="text-[15px] text-ink/65 mt-[10px] font-sans">
      <span class="en">Information according to § 5 TMG</span>
      <span class="de">Angaben gemäß § 5 TMG</span>
    </div>

    <section class="pt-7 pb-7 border-t border-ink/[0.12] mt-12 first:mt-12">
      <h2 class="mb-3 font-display font-normal text-[22px] leading-[1.2] tracking-[-0.01em] text-ink">
        <span class="en">Operator</span><span class="de">Betreiber</span>
      </h2>
      <p class="m-0 text-[15px] leading-[1.65] text-ink/[0.78]">
        Leon Bojanowski<br />Marienstraße 3b<br />14532 Stahnsdorf<br />
        <span class="en">Germany</span><span class="de">Deutschland</span>
      </p>
    </section>

    <section class="pt-7 pb-7 border-t border-ink/[0.12]">
      <h2 class="mb-3 font-display font-normal text-[22px] leading-[1.2] tracking-[-0.01em] text-ink">
        <span class="en">Contact</span><span class="de">Kontakt</span>
      </h2>
      <p class="m-0 text-[15px] leading-[1.65] text-ink/[0.78]">leongaborbojanowski@proton.me</p>
    </section>

    <section class="pt-7 pb-7 border-t border-ink/[0.12]">
      <h2 class="mb-3 font-display font-normal text-[22px] leading-[1.2] tracking-[-0.01em] text-ink">
        <span class="en">Informational use only</span><span class="de">Nur zur Information</span>
      </h2>
      <p class="m-0 text-[15px] leading-[1.65] text-ink/[0.78] text-pretty">
        <span class="en">Wattlyzer provides estimates and recommendation support, not guaranteed outcomes or professional advice. All calculations are presented as estimates and are not suitable for critical decisions without independent verification.</span>
        <span class="de">Wattlyzer liefert Schätzungen und Empfehlungsunterstützung, keine garantierten Ergebnisse oder professionelle Beratung. Alle Berechnungen sind Schätzwerte und nicht für kritische Entscheidungen ohne unabhängige Überprüfung geeignet.</span>
      </p>
    </section>
  </main>

  <div class="px-8 py-8 border-t border-ink/10 text-center font-mono text-[11px] tracking-[0.1em] text-ink/50">
    © 2026 Wattlyzer · Impressum
  </div>
</Layout>

<script>
  function setLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem('wattlyzer-lang', lang);
    }
    document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.l === lang);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-l]').forEach((btn) => {
    btn.addEventListener('click', () => setLang(btn.dataset.l!));
  });

  const initLang =
    (typeof localStorage !== 'undefined' && localStorage.getItem('wattlyzer-lang')) || 'en';
  setLang(initLang);
</script>
