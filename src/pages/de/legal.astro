      <a href="/de/" class="back-link">← wattlyzer.de</a>
      <div class="lang-toggle">
        <a class="lang-btn" href="/legal/">EN</a>
        <span class="lang-sep">·</span>
        <a class="lang-btn active" href="/de/legal/">DE</a>
